# ─── UDISE ETL Pipeline — Environment Variables ──────────────────────────────
#
# Copy this file to .env and adjust values, or export them in your shell.
# All variables have sensible defaults if omitted.
#
# ─────────────────────────────────────────────────────────────────────────────

# Target state (UDISE state code).  128 = Uttar Pradesh.
STATE_ID=128

# Academic year ID.  11 = 2022-23.
YEAR_ID=11

# Max districts processed in parallel (keep 2-4 to avoid rate limiting).
CONCURRENT_DISTRICTS=3

# Max report downloads per district running in parallel.
CONCURRENT_REPORTS=2

# Retry configuration
RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=2000

# Directories
OUTPUT_DIR=./output
TEMP_DIR=./temp
LOGS_DIR=./logs

# Set to "true" to skip all HTTP calls (useful for testing pipeline logic).
DRY_RUN=false

# Set to "true" to persist extracted CSVs to TEMP_DIR for debugging.
KEEP_TEMP=false

# Winston log level: error | warn | info | debug
LOG_LEVEL=info

# UDISE+ session cookie — rotate when server returns 401/403.
JSESSIONID=A~211995EB6D4EC5EEECDFA6B56BD108B5

# PostgreSQL
PG_USER=udise_data_dbuser
PG_HOST=llforg-dashboards-database.ctycs80ogs1x.ap-south-1.rds.amazonaws.com
PG_DATABASE=surveycto_database
PG_PASSWORD=lS0hFeRt4rHj
PG_PORT=5432

# Runtime
NODE_ENV=development
PORT=3000

# Keep external APIs safe by serializing requests.
CONCURRENT_DISTRICTS=1
CONCURRENT_REPORTS=1
REQUEST_DELAY_MS=1200
